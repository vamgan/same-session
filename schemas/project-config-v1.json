{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vamgan/same-session/schemas/project-config-v1.json",
  "title": "SameSession project configuration v1",
  "description": "Schema for the JSON-equivalent representation of .samesession/config.toml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "store", "encryption"],
  "properties": {
    "version": { "const": 1 },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remote", "auto_push"],
      "properties": {
        "remote": { "type": "string", "minLength": 1 },
        "auto_push": { "type": "boolean" }
      }
    },
    "encryption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recipients"],
      "properties": {
        "recipients": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^age1[0-9a-z]+$" }
        }
      }
    }
  }
}
